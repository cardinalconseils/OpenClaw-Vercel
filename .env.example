# ============================================
# OpenClaw — Service Matchmaker
# Environment Variables
# ============================================

# --- Telnyx (Voice & SMS) ---
TELNYX_API_KEY=
TELNYX_API_SECRET=
TELNYX_PUBLIC_KEY=
TELNYX_APP_ID=
TELNYX_PHONE_NUMBER=
TELNYX_CONNECTION_ID=

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_DEVICE_TOKEN=

# --- Google Maps / Places API ---
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# --- LLM Providers ---
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- BuyMeACoffee ---
BUYMEACOFFEE_USERNAME=

# --- Observability ---
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=openclaw-dev
LANGCHAIN_TRACING_V2=true

# --- Deployment ---
PORT=18789
NODE_ENV=development
